import { promptAction } from '@kit.ArkUI';

// NAPI bindings are loaded from libphantom.so by DevEco Studio.
// The TypeScript declarations would normally be generated by ohos-rs.
declare module 'libphantom.so' {
  function phantomHarmonyStart(fd: number, uri: string, mode: string): number;
  function phantomHarmonyStop(): number;
  function phantomHarmonyGetStatus(): number;
  function phantomHarmonyGetLastError(): string;
  function phantomHarmonyGetLogs(since: number): [string[], number];
}

@Entry
@Component
struct Index {
  @State serverUri: string = 'phantom://key@example.com:443';
  @State proxyMode: string = 'smart';
  @State status: string = 'Idle';
  @State logs: string = '';
  @State isRunning: boolean = false;
  private logCursor: number = 0;
  private timer: number = -1;

  aboutToDisappear(): void {
    if (this.timer !== -1) {
      clearInterval(this.timer);
    }
  }

  startPolling(): void {
    this.timer = setInterval(() => {
      try {
        const status = (globalThis as any).phantomHarmonyGetStatus();
        this.status = this.statusText(status);
        this.isRunning = (status === 2);

        const result: [string[], number] = (globalThis as any).phantomHarmonyGetLogs(this.logCursor);
        const lines = result[0];
        this.logCursor = result[1];
        if (lines.length > 0) {
          this.logs += '\n' + lines.join('\n');
        }
      } catch (e) {
        console.error('[Phantom] poll error: ' + JSON.stringify(e));
      }
    }, 500);
  }

  stopPolling(): void {
    if (this.timer !== -1) {
      clearInterval(this.timer);
      this.timer = -1;
    }
  }

  statusText(code: number): string {
    switch (code) {
      case 1: return 'Connecting...';
      case 2: return 'Connected';
      case 3: {
        try {
          return (globalThis as any).phantomHarmonyGetLastError();
        } catch (e) {
          return 'Error';
        }
      }
      default: return 'Idle';
    }
  }

  build() {
    Column({ space: 16 }) {
      Text('Phantom')
        .fontSize(28)
        .fontWeight(FontWeight.Bold)
        .margin({ top: 40, bottom: 20 })

      Text(this.status)
        .fontSize(16)
        .fontColor(this.isRunning ? '#0F5132' : '#FF0000')

      TextInput({ placeholder: 'phantom://key@host:port', text: this.serverUri })
        .width('90%')
        .enabled(!this.isRunning)
        .onChange((value: string) => { this.serverUri = value; })

      Row({ space: 12 }) {
        Button('Global', { type: ButtonType.Capsule })
          .backgroundColor(this.proxyMode === 'proxy' ? '#007DFF' : '#999999')
          .onClick(() => { if (!this.isRunning) this.proxyMode = 'proxy'; })
        Button('Auto', { type: ButtonType.Capsule })
          .backgroundColor(this.proxyMode === 'smart' ? '#007DFF' : '#999999')
          .onClick(() => { if (!this.isRunning) this.proxyMode = 'smart'; })
        Button('Direct', { type: ButtonType.Capsule })
          .backgroundColor(this.proxyMode === 'direct' ? '#007DFF' : '#999999')
          .onClick(() => { if (!this.isRunning) this.proxyMode = 'direct'; })
      }

      Button(this.isRunning ? 'Stop Tunnel' : 'Start Tunnel')
        .width('90%')
        .height(48)
        .backgroundColor(this.isRunning ? '#FF4444' : '#007DFF')
        .onClick(() => {
          if (this.isRunning) {
            try {
              (globalThis as any).phantomHarmonyStop();
            } catch (e) {
              console.error('[Phantom] stop error: ' + JSON.stringify(e));
            }
            this.stopPolling();
            this.isRunning = false;
            this.status = 'Idle';
          } else {
            if (this.serverUri.trim().length === 0) {
              promptAction.showToast({ message: 'Please enter a server URI' });
              return;
            }
            // HarmonyOS: request VPN permission and obtain fd via VpnExtensionAbility.
            // This is a placeholder for the native fd that would come from the system.
            const placeholderFd = -1;
            try {
              const rc = (globalThis as any).phantomHarmonyStart(placeholderFd, this.serverUri, this.proxyMode);
              if (rc !== 0) {
                promptAction.showToast({ message: 'Tunnel start failed: ' + rc });
              } else {
                this.startPolling();
              }
            } catch (e) {
              promptAction.showToast({ message: 'Native call error: ' + JSON.stringify(e) });
            }
          }
        })

      Text('Connection Logs')
        .width('90%')
        .textAlign(TextAlign.Start)
        .fontSize(14)
        .fontWeight(FontWeight.Medium)

      Scroll() {
        Text(this.logs)
          .width('90%')
          .fontSize(12)
          .fontFamily('monospace')
          .textAlign(TextAlign.Start)
      }
      .width('100%')
      .layoutWeight(1)
      .backgroundColor('#F5F5F5')
      .padding(12)
    }
    .width('100%')
    .height('100%')
    .backgroundColor('#FFFFFF')
  }
}
